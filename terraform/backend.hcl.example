# Copy this file to backend.hcl and fill in the values produced by
# `terraform output` from terraform/bootstrap/.
#
# Then initialise (or re-initialise) the main stack:
#   terraform init -backend-config=backend.hcl

bucket         = "marukyu-tfstate-<YOUR_AWS_ACCOUNT_ID>"
key            = "marukyu/terraform.tfstate"
region         = "ap-southeast-1"
dynamodb_table = "marukyu-tfstate-lock"
encrypt        = true
